// AI Phone Platform — database schema (PostgreSQL).
//
// Multi-tenancy rule: every tenant-scoped table carries `tenantId` and is
// indexed on it. The application layer ALWAYS filters by the tenantId taken
// from the authenticated context (never from client input). When deployed on
// Supabase, the SQL in prisma/rls.sql additionally enables Postgres
// Row-Level Security as defense-in-depth — see docs/DATABASE.md.
//
// PII fields (phone numbers, caller email, transcript text) are stored
// encrypted at rest via AES-256-GCM in the application layer; their columns
// hold ciphertext, hence the `Enc` suffix and String type.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  // Platform-level staff roles (operate across tenants, scoped capabilities).
  platform_support
  billing
  tenant_admin
  tenant_member
  read_only
}

enum Plan {
  starter
  business
  enterprise
}

enum TelephonyProvider {
  twilio
  telnyx
  sip
}

enum CallStatus {
  ringing
  consent_pending
  in_progress
  summarizing
  completed
  declined
  failed
}

enum MessageRole {
  assistant
  caller
  system
}

enum QuestionType {
  free_text
  yes_no
  multiple_choice
  scale
  datetime
  phone
  email
  budget
  urgency
}

enum LeadCategory {
  A
  B
  C
}

enum InvoiceStatus {
  open
  finalized
  paid
  void
}

model Tenant {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  locale             String   @default("de")
  monthlyBudgetLimit Decimal? @db.Decimal(12, 4)
  autoPauseOnBudget  Boolean  @default(false)
  paused             Boolean  @default(false)
  // Admin-console metadata
  industry           String?
  country            String   @default("DE")
  timezone           String   @default("Europe/Berlin")
  plan               Plan     @default(starter)
  // Wizard choices: how telephony / OpenAI are sourced for this tenant.
  telephonyMode      String   @default("platform_twilio")
  openaiMode         String   @default("platform")
  // White-label / branding
  brandName          String?
  brandColor         String?
  // Realtime (ConversationRelay) conversations — per-tenant beta flag. The
  // global REALTIME_ENABLED env var must also be on; default is the classic
  // turn-based flow.
  realtimeEnabled    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenantUsers      TenantUser[]
  phoneNumbers     PhoneNumber[]
  assistants       Assistant[]
  questionnaires   Questionnaire[]
  calls            Call[]
  usageEvents      UsageEvent[]
  invoices         Invoice[]
  emailLogs        EmailLog[]
  auditLogs        AuditLog[]
  emailRecipients  EmailRecipient[]
  retentionSetting DataRetentionSetting?
  calendarConnections CalendarConnection[]

  @@map("tenants")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String?
  name         String?
  // Admin-console account controls.
  locked       Boolean      @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  tenantUsers  TenantUser[]

  @@map("users")
}

// Join table: a user can belong to multiple tenants with a per-tenant role.
model TenantUser {
  id       String @id @default(uuid())
  tenantId String
  userId   String
  role     Role   @default(tenant_member)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_users")
}

model PhoneNumber {
  id          String            @id @default(uuid())
  tenantId    String
  provider    TelephonyProvider
  // The ROUTING DID: the platform-owned number an inbound call actually lands
  // on (the forward target). Encrypted, with a deterministic lookup hash so we
  // can match an inbound call to a tenant without decrypting every row. The
  // caller keeps their own number and forwards it here — the CPaaS (Twilio/
  // Telnyx) remains the licensed carrier, the platform stays a software layer.
  e164Enc     String
  e164Hash    String            @unique
  // The customer's OWN business number (the one they keep and forward FROM).
  // Display metadata only; never used for routing. Encrypted (PII).
  displayNumberEnc String?
  // Forwarding lifecycle for the "keep your number" flow:
  //   pending  — DID assigned, waiting for the first forwarded call to arrive
  //   active   — verified: a call has been received on the DID (or no
  //              forwarding is required because the DID is dialed directly)
  forwardingStatus String            @default("pending")
  assistantId String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assistant Assistant? @relation(fields: [assistantId], references: [id])
  calls     Call[]

  @@index([tenantId])
  @@map("phone_numbers")
}

model Assistant {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  greetingText    String
  consentText     String
  systemPrompt    String
  voice           String   @default("alloy")
  locale          String   @default("de")
  recordAudio     Boolean  @default(false)
  questionnaireId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questionnaire Questionnaire? @relation(fields: [questionnaireId], references: [id])
  phoneNumbers  PhoneNumber[]
  calls         Call[]

  @@index([tenantId])
  @@map("assistants")
}

model Questionnaire {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions  QuestionnaireQuestion[]
  assistants Assistant[]

  @@index([tenantId])
  @@map("questionnaires")
}

model QuestionnaireQuestion {
  id              String       @id @default(uuid())
  tenantId        String
  questionnaireId String
  key             String
  prompt          String
  type            QuestionType
  required        Boolean      @default(false)
  order           Int
  // Options for multiple_choice, scale bounds, and conditional triggers are
  // stored as JSON to keep the schema flexible.
  options         Json?
  scaleMin        Int?
  scaleMax        Int?
  condition       Json?

  questionnaire Questionnaire @relation(fields: [questionnaireId], references: [id], onDelete: Cascade)

  @@unique([questionnaireId, key])
  @@index([tenantId])
  @@index([questionnaireId])
  @@map("questionnaire_questions")
}

model Call {
  id                String            @id @default(uuid())
  tenantId          String
  assistantId       String
  phoneNumberId     String
  provider          TelephonyProvider
  providerCallId    String            @unique
  status            CallStatus        @default(ringing)
  // Caller's number, encrypted.
  fromNumberEnc     String
  consentGiven      Boolean           @default(false)
  callerEmailConsent Boolean          @default(false)
  leadCategory      LeadCategory?
  durationSeconds   Int               @default(0)
  totalCost         Decimal?          @db.Decimal(12, 6)
  startedAt         DateTime          @default(now())
  endedAt           DateTime?
  // Conversation engine cursor (which question index we are on).
  state             Json?

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assistant   Assistant   @relation(fields: [assistantId], references: [id])
  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id])
  messages    CallMessage[]
  answers     CallAnswer[]
  summary     CallSummary?
  usageEvent  UsageEvent?
  appointment CallAppointment?

  @@index([tenantId])
  @@index([tenantId, startedAt])
  @@map("calls")
}

// Outcome of the calendar-booking attempt for a call. One per call.
//   detected     — a date/time was recognized but no calendar is connected
//   booked       — event created on the tenant's calendar
//   conflict     — desired slot was busy; not booked (alternatives were offered)
//   failed       — a provider error prevented booking
model CallAppointment {
  id         String    @id @default(uuid())
  tenantId   String
  callId     String    @unique
  provider   String?
  calendarId String?
  status     String
  startAt    DateTime?
  eventId    String?
  htmlLink   String?
  error      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("call_appointments")
}

model CallMessage {
  id        String      @id @default(uuid())
  tenantId  String
  callId    String
  role      MessageRole
  // Transcript text, encrypted.
  textEnc   String
  createdAt DateTime    @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([callId])
  @@map("call_messages")
}

model CallAnswer {
  id          String       @id @default(uuid())
  tenantId    String
  callId      String
  questionKey String
  type        QuestionType
  // Normalized value as JSON and the encrypted raw transcript snippet.
  value       Json
  rawTextEnc  String
  createdAt   DateTime     @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@unique([callId, questionKey])
  @@index([tenantId])
  @@index([callId])
  @@map("call_answers")
}

model CallSummary {
  id                String       @id @default(uuid())
  tenantId          String
  callId            String       @unique
  callerName        String?
  // Caller email, encrypted (PII).
  callerEmailEnc    String?
  concern           String?
  summary           String
  leadCategory      LeadCategory
  recommendedAction String
  createdAt         DateTime     @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("call_summaries")
}

model UsageEvent {
  id              String   @id @default(uuid())
  tenantId        String
  callId          String   @unique
  durationSeconds Int
  sttCost         Decimal  @db.Decimal(12, 6)
  ttsCost         Decimal  @db.Decimal(12, 6)
  llmCost         Decimal  @db.Decimal(12, 6)
  telephonyCost   Decimal  @db.Decimal(12, 6)
  platformMarkup  Decimal  @db.Decimal(12, 6)
  totalCost       Decimal  @db.Decimal(12, 6)
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  call   Call   @relation(fields: [callId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("usage_events")
}

model Invoice {
  id          String        @id @default(uuid())
  tenantId    String
  periodStart DateTime
  periodEnd   DateTime
  totalAmount Decimal       @db.Decimal(12, 4)
  currency    String        @default("EUR")
  status      InvoiceStatus @default(open)
  stripeId    String?
  createdAt   DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, periodStart])
  @@index([tenantId])
  @@map("invoices")
}

model EmailRecipient {
  id        String   @id @default(uuid())
  tenantId  String
  email     String
  label     String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("email_recipients")
}

model EmailLog {
  id        String   @id @default(uuid())
  tenantId  String
  callId    String?
  // Recipient address, encrypted.
  toEnc     String
  subject   String
  kind      String // "tenant_summary" | "caller_summary" | "budget_alert"
  status    String // "sent" | "failed"
  error     String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("email_logs")
}

// Append-only audit trail for access to and mutation of sensitive data.
model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  actorId    String?
  actorEmail String?
  action     String // e.g. "call.read", "call.delete", "questionnaire.update"
  targetType String?
  targetId   String?
  ip         String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model DataRetentionSetting {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  retentionDays Int      @default(90)
  storeAudio    Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("data_retention_settings")
}

// --- Platform-level (non-tenant) tables for the Super-Admin console ---------

// Key/value store for non-secret platform configuration (AI defaults, provider
// preferences, feature flags). Secrets stay in the environment / secret manager.
model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("platform_settings")
}

// Versioned global system prompt with rollback support.
model PromptVersion {
  id        String   @id @default(uuid())
  version   Int      @unique @default(autoincrement())
  label     String?
  content   String
  active    Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())

  @@map("prompt_versions")
}

// Backup run metadata (the actual dump lives in object storage / a volume).
model Backup {
  id          String    @id @default(uuid())
  status      String    @default("pending") // pending | running | completed | failed
  sizeBytes   BigInt?
  location    String?
  note        String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdBy   String?

  @@map("backups")
}

// A tenant's connected calendar (Google or Microsoft). OAuth tokens are secrets
// and are stored encrypted at rest (AES-256-GCM), never exposed to the frontend.
// When an appointment call captures a date/time, the assistant writes the event
// to this calendar. One connection per tenant+provider.
model CalendarConnection {
  id             String   @id @default(uuid())
  tenantId       String
  provider       String // "google" | "microsoft"
  // Encrypted OAuth tokens.
  accessTokenEnc String
  refreshTokenEnc String?
  expiresAt      DateTime?
  // Target calendar + the account it belongs to (for display).
  calendarId     String   @default("primary")
  accountEmail   String?
  scope          String?
  status         String   @default("active") // active | revoked | error
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("calendar_connections")
}

// Platform-owned pool of routing DIDs for the "keep your number" flow. The
// operator pre-provisions numbers here (bought via a provider API or by hand);
// when a tenant keeps their own number, one AVAILABLE routing number is claimed
// automatically and bound to a tenant PhoneNumber — so the customer never has
// to type a routing number given out by support. This is a platform-level table
// (not tenant-scoped): a routing number belongs to the platform until assigned.
model RoutingNumber {
  id                    String            @id @default(uuid())
  provider              TelephonyProvider @default(twilio)
  // The platform-owned DID, encrypted, with a deterministic lookup hash so the
  // same number can't be added to the pool twice.
  e164Enc               String
  e164Hash              String            @unique
  country               String            @default("DE")
  // available → claimable; assigned → bound to a tenant PhoneNumber.
  status                String            @default("available")
  // Whether the DID's inbound voice webhook is wired to the platform.
  webhookConfigured     Boolean           @default(false)
  // Set when status = assigned. Not a FK (no cascade): released on delete.
  assignedTenantId      String?
  assignedPhoneNumberId String?           @unique
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([status])
  @@map("routing_numbers")
}

// Lightweight application event log surfaced in the admin "Logs" view. Audit of
// admin actions continues to use the existing audit_logs table.
model AppLog {
  id        String   @id @default(uuid())
  level     String   @default("info") // info | warn | error
  channel   String // api | login | openai | telephony | webhook | system
  message   String
  tenantId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([level])
  @@index([createdAt])
  @@map("app_logs")
}
