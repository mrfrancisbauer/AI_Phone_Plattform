# Production stack env (docker-compose.prod.yml). Copy to .env.prod and fill in.
# NEVER commit .env.prod. Prefer a real secret manager over a file in production.

# Public URLs (used for webhook callbacks, CORS, and the dashboard's API URL)
API_PUBLIC_URL=https://api.yourdomain.com
WEB_ORIGIN=https://app.yourdomain.com

# Database (bundled Postgres container; or point DATABASE_URL at managed Postgres)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=ai_phone

# Secrets — generate:
#   ENCRYPTION_KEY: openssl rand -hex 32
#   JWT_SECRET:     openssl rand -base64 48
ENCRYPTION_KEY=
JWT_SECRET=

# Telephony
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=true

# LLM (optional — falls back to a local summarizer when empty)
OPENAI_API_KEY=

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="AI Phone Assistant <assistant@yourdomain.com>"

# Pricing
PLATFORM_MARKUP_PERCENT=0.30
